// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  CAMPAIGN_MANAGER
  VIEWER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(VIEWER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  contactLists ContactList[]
  emailTemplates EmailTemplate[]
  campaigns Campaign[]
  
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model ContactList {
  id          String   @id @default(cuid())
  name        String
  description String?
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  owner       User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members     ContactListMember[]
  contacts     Contact[]
  recipientLists CampaignRecipientList[]
  excludedLists CampaignExcludedList[]
  
  @@map("contact_lists")
}

model Contact {
  id          String   @id @default(cuid())
  email       String   @unique
  firstName   String?
  lastName    String?
  phone       String?
  company     String?
  city        String?
  tags        String?   // JSON array of tags
  status      ContactStatus @default(ACTIVE)
  source      ContactSource @default(MANUAL)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  lists       ContactListMember[]
  contactLists ContactList[]
  
  @@map("contacts")
}

model ContactListMember {
  id            String      @id @default(cuid())
  contactList    ContactList @relation(fields: [contactListId], references: [id], onDelete: Cascade)
  contactListId  String
  contact        Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId      String
  createdAt      DateTime     @default(now())
  
  @@unique([contactListId, contactId])
  @@map("contact_list_members")
}

model Segment {
  id          String   @id @default(cuid())
  name        String
  description String?
  criteria    Json?     // Store segmentation criteria as JSON
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  recipientCampaigns CampaignRecipientSegment[]

  @@map("segments")
}

enum ContactStatus {
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED
}

enum ContactSource {
  IMPORT
  MANUAL
  API
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PAUSED
  CANCELLED
}

model EmailTemplate {
  id          String   @id @default(cuid())
  name        String
  category    String?
  thumbnail   String?
  html        String   @db.Text
  json        String?  @db.Text
  createdBy   String
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user User @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  campaigns Campaign[]

  // Prevent duplicate template names per user
  @@unique([createdBy, name])
  @@map("email_templates")
}

model Campaign {
  id                    String         @id @default(cuid())
  name                  String
  subject               String
  previewText           String?
  senderName            String?
  senderEmail           String?
  replyToEmail           String?
  status                CampaignStatus @default(DRAFT)
  scheduledAt           DateTime?
  sentAt                DateTime?
  timezone              String?
  recipientCount        Int            @default(0)
  estimatedRecipients   Int?
  openRate              Float?
  clickRate             Float?
  totalSent             Int             @default(0)
  totalOpened           Int             @default(0)
  totalClicked          Int             @default(0)
  tags                  String?         // JSON array of tags
  currentStep           Int             @default(1)  // Wizard progress tracking
  templateId            String?
  createdBy              String
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  // Relations
  user User @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  template EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  recipientLists CampaignRecipientList[]
  recipientSegments CampaignRecipientSegment[]
  excludedLists CampaignExcludedList[]
  testSends CampaignTestSend[]
  activityLogs CampaignActivityLog[]

  // Prevent duplicate campaign names per user
  @@unique([createdBy, name])
  @@map("campaigns")
}

model CampaignRecipientSegment {
  id           String   @id @default(cuid())
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId   String
  segment      Segment  @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  segmentId    String
  createdAt    DateTime @default(now())

  @@unique([campaignId, segmentId])
  @@map("campaign_recipient_segments")
}

model CampaignRecipientList {
  id           String   @id @default(cuid())
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId   String
  contactList  ContactList @relation(fields: [contactListId], references: [id], onDelete: Cascade)
  contactListId String
  createdAt    DateTime @default(now())

  @@unique([campaignId, contactListId])
  @@map("campaign_recipient_lists")
}

model CampaignExcludedList {
  id           String   @id @default(cuid())
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId   String
  contactList  ContactList @relation(fields: [contactListId], references: [id], onDelete: Cascade)
  contactListId String
  createdAt    DateTime @default(now())

  @@unique([campaignId, contactListId])
  @@map("campaign_excluded_lists")
}

model CampaignTestSend {
  id         String   @id @default(cuid())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId String
  email      String
  sentBy     String
  sentAt     DateTime @default(now())

  @@map("campaign_test_sends")
}

model CampaignActivityLog {
  id        String   @id @default(cuid())
  campaign  Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId String
  actorId   String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  @@map("campaign_activity_logs")
}

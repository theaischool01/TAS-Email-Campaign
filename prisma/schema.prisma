generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String          @id @default(cuid())
  name             String?
  email            String          @unique
  password         String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  emailVerified    DateTime?
  image            String?
  role             Role            @default(ADMIN)
  resetToken       String?         @unique
  resetTokenExpiry DateTime?
  accounts         Account[]
  campaigns        Campaign[]
  contactLists     ContactList[]
  emailTemplates   EmailTemplate[]
  sessions         Session[]
  contacts         Contact[]
  segments         Segment[]
  settings         Settings?
  suppressionList  SuppressionList[]
  emailDeliveries  EmailDelivery[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model ContactList {
  id                   String                  @id @default(cuid())
  name                 String
  description          String?
  ownerId              String
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  ContactToContactList ContactToContactList[]
  excludedLists        CampaignExcludedList[]
  recipientLists       CampaignRecipientList[]
  members              ContactListMember[]
  owner                User                    @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@map("contact_lists")
}

model Contact {
  id                   String                 @id @default(cuid())
  email                String
  userId               String
  firstName            String?
  lastName             String?
  phone                String?
  status               ContactStatus          @default(ACTIVE)
  source               ContactSource          @default(MANUAL)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  city                 String?
  company              String?
  tags                 String?
  softBounceCount      Int                    @default(0)
  ContactToContactList ContactToContactList[]
  activityLogs         CampaignActivityLog[]
  lists                ContactListMember[]
  emailDeliveries      EmailDelivery[]
  user                 User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
  @@index([userId, createdAt])
  @@map("contacts")
}

model ContactListMember {
  id            String      @id @default(cuid())
  contactListId String
  contactId     String
  createdAt     DateTime    @default(now())
  contact       Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactList   ContactList @relation(fields: [contactListId], references: [id], onDelete: Cascade)

  @@unique([contactListId, contactId])
  @@map("contact_list_members")
}

model Segment {
  id                 String                     @id @default(cuid())
  name               String
  description        String?
  criteria           Json?
  userId             String
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  recipientCampaigns CampaignRecipientSegment[]
  user               User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("segments")
}

model EmailTemplate {
  id        String     @id @default(cuid())
  name      String
  category  String?
  thumbnail String?
  html      String
  json      String?
  createdBy String?
  isPublic  Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  isSystem  Boolean    @default(false)
  systemTemplateId String?
  campaigns Campaign[]
  user      User?      @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@unique([createdBy, name])
  @@map("email_templates")
}

model Campaign {
  id                  String                     @id @default(cuid())
  name                String
  subject             String
  previewText         String?
  senderName          String?
  senderEmail         String?
  replyToEmail        String?
  status              CampaignStatus             @default(DRAFT)
  scheduledAt         DateTime?
  sentAt              DateTime?
  timezone            String?
  recipientCount      Int                        @default(0)
  estimatedRecipients Int?
  openRate            Float?
  clickRate           Float?
  totalSent           Int                        @default(0)
  totalOpened         Int                        @default(0)
  totalClicked        Int                        @default(0)
  tags                String?
  templateId          String?
  createdBy           String
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  currentStep         Int                        @default(1)
  isRecurring         Boolean                    @default(false)
  recurrenceInterval  String?
  totalBounced        Int                        @default(0)
  totalComplained     Int                        @default(0)
  totalFailed         Int                        @default(0)
  totalUnsubscribed   Int                        @default(0)
  activityLogs        CampaignActivityLog[]
  excludedLists       CampaignExcludedList[]
  recipientLists      CampaignRecipientList[]
  recipientSegments   CampaignRecipientSegment[]
  testSends           CampaignTestSend[]
  emailDeliveries     EmailDelivery[]
  user                User                       @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  template            EmailTemplate?             @relation(fields: [templateId], references: [id])

  @@unique([createdBy, name])
  @@index([templateId])
  @@index([createdBy, createdAt])
  @@map("campaigns")
}

model CampaignRecipientSegment {
  id         String   @id @default(cuid())
  campaignId String
  segmentId  String
  createdAt  DateTime @default(now())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  segment    Segment  @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@unique([campaignId, segmentId])
  @@map("campaign_recipient_segments")
}

model CampaignRecipientList {
  id            String      @id @default(cuid())
  campaignId    String
  contactListId String
  createdAt     DateTime    @default(now())
  campaign      Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactList   ContactList @relation(fields: [contactListId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactListId])
  @@map("campaign_recipient_lists")
}

model CampaignExcludedList {
  id            String      @id @default(cuid())
  campaignId    String
  contactListId String
  createdAt     DateTime    @default(now())
  campaign      Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactList   ContactList @relation(fields: [contactListId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactListId])
  @@map("campaign_excluded_lists")
}

model CampaignTestSend {
  id         String   @id @default(cuid())
  campaignId String
  email      String
  sentBy     String
  sentAt     DateTime @default(now())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("campaign_test_sends")
}

model CampaignActivityLog {
  id         String   @id @default(cuid())
  campaignId String
  actorId    String
  action     String
  metadata   Json?
  createdAt  DateTime @default(now())
  contactId  String?
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact    Contact? @relation(fields: [contactId], references: [id])

  @@index([campaignId, action])
  @@index([campaignId, contactId, action])
  @@index([campaignId, createdAt(sort: Desc)])
  @@index([contactId])
  @@index([createdAt(sort: Desc)])
  @@map("campaign_activity_logs")
}

model Settings {
  id               String   @id @default(cuid())
  userId           String   @unique
  orgName          String   @default("My Organisation")
  orgLogo          String?
  defaultFromEmail String?
  defaultFromName  String?
  awsAccessKey     String?
  awsSecretKey     String?
  awsRegion        String?  @default("us-east-1")
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("settings")
}

model LoginAttempt {
  id          String    @id @default(cuid())
  ip          String    @unique
  attempts    Int       @default(0)
  lockedUntil DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("login_attempts")
}

model SuppressionList {
  id        String   @id @default(cuid())
  userId    String
  email     String
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
  @@map("suppression_list")
}

model ContactToContactList {
  A             String
  B             String
  contacts      Contact     @relation(fields: [A], references: [id], onDelete: Cascade)
  contact_lists ContactList @relation(fields: [B], references: [id], onDelete: Cascade)

  @@id([A, B], map: "_ContactToContactList_AB_pkey")
  @@index([B], map: "_ContactToContactList_B_index")
  @@map("_ContactToContactList")
}

enum Role {
  ADMIN
}

enum ContactStatus {
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED
}

enum ContactSource {
  IMPORT
  MANUAL
  API
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PAUSED
  CANCELLED
  FAILED
}

enum DeliveryStatus {
  SENDING
  SENT
  FAILED
}

model EmailDelivery {
  id String @id @default(cuid())

  campaignId String
  userId String

  contactId String?
  recipientEmail String

  status DeliveryStatus @default(SENDING)

  sesMessageId String?

  failureCode String?
  failureReason String?

  retryCount Int @default(0)

  startedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([campaignId, recipientEmail])

  @@index([campaignId, status])
  @@index([userId, createdAt])
  @@index([contactId])
  @@map("email_deliveries")
}

enum WorkerStatus {
  STARTING
  HEALTHY
  SHUTTING_DOWN
  FAILED
}

model WorkerHeartbeat {
  id                 String       @id
  hostname           String
  processId          Int
  status             WorkerStatus @default(STARTING)
  version            String?
  environment        String?
  activeMessages     Int          @default(0)
  successfulMessages Int          @default(0)
  failedMessages     Int          @default(0)
  memoryUsageMb      Int
  uptimeSeconds      Int
  startedAt          DateTime     @default(now())
  lastSeenAt         DateTime     @updatedAt

  @@index([status, lastSeenAt])
  @@map("worker_heartbeats")
}

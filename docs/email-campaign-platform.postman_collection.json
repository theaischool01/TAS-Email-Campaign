		{
			"name": "Auth",
			"description": "Endpoints for user registration and session management.",
			"item": [
				{
					"name": "Register New User",
					"description": "Create a new user account with a default VIEWER role.",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/register",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"register"
							]
						}
					},
					"response": [
						{
							"name": "Success",
							"status": "Created",
							"code": 201,
							"_postman_previewlanguage": "json",
							"body": "{\n    \"message\": \"Account created successfully\",\n    \"user\": {\n        \"id\": \"user_123\",\n        \"name\": \"Test User\",\n        \"email\": \"test@example.com\",\n        \"role\": \"VIEWER\"\n    }\n}"
						},
						{
							"name": "Conflict (Email Exists)",
							"status": "Conflict",
							"code": 409,
							"_postman_previewlanguage": "json",
							"body": "{\n    \"error\": \"User with this email already exists\"\n}"
						}
					]
				},
				{
					"name": "Check Session",
					"description": "Verify if the current user is authenticated and get their profile.",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/auth/session",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"session"
							]
						}
					},
					"response": []
				}
			]
		},

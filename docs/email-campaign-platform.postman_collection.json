				{
					"name": "Create Campaign Draft",
					"description": "Initialize a new campaign draft. Automatically captures campaign_id for downstream requests.",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.id) {",
									"    pm.environment.set(\"campaign_id\", jsonData.data.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Holiday Sale 2026\",\n  \"subject\": \"Exclusive Holiday Deals Inside! 🎁\",\n  \"previewText\": \"Unlock up to 50% off.\",\n  \"senderName\": \"Marketing Team\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/campaigns",
							"host": [
